# ===========================================================================
# Agent 智能体平台 · 环境变量模板
# 用法：cp .env.example .env，然后把下面的占位值换成你自己的真实密钥。
# 本文件可安全提交到 Git(不含真实密钥)；.env 已被 .gitignore 忽略。
# ===========================================================================

# ---------------------------------------------------------------------------
# 1. Supabase 数据库 (PostgreSQL + pgvector)
#    获取位置：Supabase 控制台 -> Project Settings -> Database
#    Supabase 提供两种连接方式，本项目两个都要用：
# ---------------------------------------------------------------------------

# 【连接池地址 · Transaction pooler】端口 6543 —— 应用运行时用(Prisma driver adapter)
# 形如：postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres
# 注意带上 ?pgbouncer=true&connection_limit=1，适配 Supabase 的 PgBouncer 池化
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# 【直连地址 · Session mode】端口 5432 —— Prisma 迁移用(prisma.config.ts 里读它)
# 形如：postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres

# 影子数据库(Prisma 迁移内部用)。Supabase 一般用不到，留空即可；本地开发可指向一个临时库。
SHADOW_DATABASE_URL=

# ---------------------------------------------------------------------------
# 2. Supabase 认证 & 存储 (Auth + Storage)
#    获取位置：Supabase 控制台 -> Project Settings -> API
#    NEXT_PUBLIC_ 前缀的变量会暴露给浏览器，只能放"可公开"的密钥(anon key)。
# ---------------------------------------------------------------------------

# 项目 URL，形如 https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# 匿名密钥(可公开，受 RLS 行级安全保护)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 服务端密钥(绕过 RLS，仅限服务端使用，绝不放进前端代码)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# 3. DeepSeek (OpenAI 兼容的 LLM provider)
#    DeepSeek API 兼容 OpenAI 接口，用 @ai-sdk/openai 的 createOpenAI 指向它即可。
#    密钥获取：https://platform.deepseek.com/ -> API Keys
# ---------------------------------------------------------------------------

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-deepseek-key

# DeepSeek 接口地址(OpenAI 兼容)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 默认对话模型：deepseek-chat(通用) / deepseek-reasoner(推理)
DEEPSEEK_MODEL=deepseek-chat

# ---------------------------------------------------------------------------
# 4. 应用配置
# ---------------------------------------------------------------------------

# 站点根地址，用于生成公开分享链接、OG 卡片等
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# 5. 硅基流动 (SiliconFlow · RAG 文本向量化 Embedding)
#    获取位置：https://siliconflow.cn -> API Keys
#    本项目用 BAAI/bge-large-zh-v1.5 (1024 维)，对应 schema 中 vector(1024)
# ---------------------------------------------------------------------------
SILICONFLOW_API_KEY=sk-your-siliconflow-key

# ---------------------------------------------------------------------------
# 6. Brave 搜索 (联网搜索工具 · 可选)
#    获取位置：https://brave.com/search/api/
#    不配则"联网搜索"工具自动降级(不报错)；配了才真正联网。
# ---------------------------------------------------------------------------
BRAVE_API_KEY=your-brave-key

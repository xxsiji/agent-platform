# Agent 智能体平台 - 环境变量模板
# 复制为 .env 后填入真实值

# Supabase
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:5432/postgres
SHADOW_DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# RAG Embedding
EMBEDDING_API_KEY=sk-your-siliconflow-key
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# 可选：联网搜索工具
BRAVE_API_KEY=your-brave-key

# 站点地址
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 飞书机器人（可选，用于飞书群 @机器人 调 Agent 平台）
# 在飞书开放平台创建一个「企业自建应用」后获取：
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your-feishu-app-secret
# 事件订阅里开启「Verification Token 校验」后填这里（可不填，不校验）
FEISHU_VERIFICATION_TOKEN=
# 机器人自己的 open_id（在应用首页「凭证与基础信息」可查），用于过滤自身消息
FEISHU_BOT_OPEN_ID=
# 让飞书机器人使用哪个已公开的 Agent（填该 Agent 的 shareSlug）
# 留空则用默认 system prompt 直接走 DeepSeek
FEISHU_AGENT_SLUG=
# 多维表自动化 webhook 鉴权密钥（飞书自动化 URL 里拼 ?secret= 这个值）
FEISHU_AUTOMATION_SECRET=your-automation-secret
